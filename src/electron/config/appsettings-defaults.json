{
  "saving": {
    "initialDir": "documents",
    "autosave": true,
    "autosaveDuration": 300000,
    "savedToast": true,
    "initialSave": true
  },
  "audio": {
    "defaultLaneCount": 1,
    "defaultVolume": 1
  },
  "theme": {
    "systemLightTheme": "white",
    "systemDarkTheme": "black"
  },
  "canvas": {
    "defaultStrokeColor": "#000000",
    "defaultFillColor": "#ffffff",
    "defaultBackgroundColor": "#ffffff",
    "defaultTool": "pencil",
    "zoomKeepOn": true,
    "zoomClickStep": 12,
    "showClearCanvasWarning": true
  },
  "boil": {
    "variations": 3,
    "holdFrames": 2,
    "amount": 2.5,
    "boilNewFrames": false
  },
  "export": {
    "defaultFormat": "png",
    "defaultResolutionIndex": 2
  },
  "onionSkin": {
    "framesBack": 1,
    "framesForward": 1,
    "prevColor": "#ff00ff",
    "nextColor": "#00b3ff"
  },
  "timeline": {
    "zoom": {
      "minZoom": 2,
      "maxZoom": 2500,
      "defaultZoom": 40,
      "zoomStep": 100
    }
  }
}
