{
  "saving": {
    "initialDir": "documents",
    "autosave": true,
    "autosaveDuration": 300000,
    "savedToast": true,
    "initialSave": true
  },
  "audio": {
    "defaultLaneCount": 1,
    "defaultVolume": 1
  },
  "theme": {
    "systemLightTheme": "white",
    "systemDarkTheme": "black"
  },
  "canvas": {
    "defaultStrokeColor": "#000000",
    "defaultFillColor": "#ffffff",
    "defaultBackgroundColor": "#ffffff",
    "defaultTool": "pencil",
    "zoomKeepOn": true,
    "zoomClickStep": 12,
    "showClearCanvasWarning": true
  },
  "timeline": {
    "zoom": {
      "minZoom": 2,
      "maxZoom": 2500,
      "defaultZoom": 40,
      "zoomStep": 100
    }
  }
}
