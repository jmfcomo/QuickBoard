{
  "window": {
    "width": 1200,
    "height": 800,
    "minWidth": 900,
    "minHeight": 750
  },
  "appURL": "app://localhost/index.html",
  "files": {
    "fileio": "./src/electron/fileio",
    "export": "./src/electron/export"
  },
  "mimeTypes": {
    ".html": "text/html",
    ".js": "application/javascript",
    ".css": "text/css",
    ".wasm": "application/wasm",
    ".png": "image/png",
    ".svg": "image/svg+xml",
    ".ico": "image/x-icon",
    ".json": "application/json",
    ".woff": "font/woff",
    ".woff2": "font/woff2",
    ".ttf": "font/ttf",
    ".mp3": "audio/mpeg"
  },
  "buildMenu": "./src/electron/menu",
  "linuxIcon": "QuickBoard_icon_Linux.png",
  "ipcChannels": {
    "theme-source": "quickboard:get-theme-source",
    "request-save": "quickboard:request-save",
    "load-data": "quickboard:load-data",
    "load-result": "quickboard:load-result",
    "save-data": "quickboard:save-data",
    "save-result": "quickboard:save-result",
    "save-binary": "quickboard:save-binary",
    "export-board": "quickboard:export-board"
  },
  "ipcExport": {
    "request-export": "quickboard:request-export",
    "save-video-file": "quickboard:save-video-file",
    "pick-export-dir": "quickboard:pick-export-dir",
    "png-export-frame": "quickboard:png-export-frame"
  },
  "ipcMenu": {
    "theme-changed": "quickboard:theme-changed",
    "undo": "quickboard:undo",
    "redo": "quickboard:redo"
  }
}
