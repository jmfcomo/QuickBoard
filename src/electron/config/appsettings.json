{
  "window": {
    "width": 1200,
    "height": 800,
    "minWidth": 900,
    "minHeight": 750
  },
  "suffix": ".sbd",
  "defaultFileName": "untitled.sbd",
  "appURL": "app://localhost/index.html",
  "initialDir": "documents",
  "board": {
    "width": 1920,
    "height": 1080,
    "defaultBackgroundColor": "#ffffff",
    "defaultDuration": 3
  },
  "audio": {
    "defaultLaneCount": 1,
    "defaultVolume": 1
  },
  "theme": {
    "systemLightTheme": "white",
    "systemDarkTheme": "black"
  },
  "canvas": {
    "defaultStrokeColor": "#000000",
    "defaultFillColor": "#ffffff",
    "defaultTool": "pencil"
  },
  "export": {
    "resolutions": [
      { "label": "480 × 270  — Draft", "scale": 0.25, "width": 480, "height": 270 },
      { "label": "960 × 540  — SD", "scale": 0.5, "width": 960, "height": 540 },
      { "label": "1920 × 1080  — HD", "scale": 1, "width": 1920, "height": 1080 },
      { "label": "3840 × 2160  — 4K", "scale": 2, "width": 3840, "height": 2160 },
      { "label": "7680 × 4320  — 8K", "scale": 4, "width": 7680, "height": 4320 }
    ],
    "defaultMaxDuration": 9999,
    "defaultFramerate": 30,
    "showClearCanvasWarning": true
  }
}
